{
  "system": {
    "description": "Project command router",
    "rules": [
      "Commands may be written with or without spaces (example: ntsystem or nt system)",
      "Commands are case-insensitive",
      "Project prefix identifies the project",
      "Command suffix identifies the data type (system, objects, ci)",
      "Additional words after a command are treated as object or CI names to load"
    ]
  },

  "projects": {
    "app": "projects/AppTool",
    "nt": "projects/NoteTaker"
  },

  "types": {
    "system": "system-backup",
    "objects": "objects-backup",
    "ci": "CI-backups"
  },

  "commands": {
    "app system": {
      "path": "projects/AppTool/system-backup"
    },

    "app objects": {
      "path": "projects/AppTool/objects-backup",
      "type": "objects"
    },

    "nt system": {
      "path": "projects/NoteTaker/system-backup"
    },

    "nt ci": {
      "path": "projects/NoteTaker/CI-backups",
      "type": "ci"
    },

    "editor": {
      "path": "projects/EditorApp"
    },

    "lpc": {
      "path": "projects/LPC-ExamSystem"
    }
  }
}
